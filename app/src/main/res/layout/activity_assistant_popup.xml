<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Gradient: transparent at top -> #0B0F1A at bottom -->
    <View
        android:id="@+id/gradientBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_overlay" />

    <!-- Bottom-aligned content -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Company name -->
        <TextView
            android:id="@+id/companyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="AURA"
            android:textColor="@color/assistant_branding"
            android:textSize="22sp"
            android:letterSpacing="0.28"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Static wave animation (expands to fill when panel has fixed height) -->
        <com.example.mobile_assistant.StaticWaveView
            android:id="@+id/waveView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="180dp"
            android:layout_marginBottom="4dp" />

        <!-- Live transcript -->
        <TextView
            android:id="@+id/transcriptText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/assistant_transcript"
            android:textSize="15sp"
            android:fontFamily="sans-serif-light"
            android:paddingHorizontal="40dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- Input row -->
        <LinearLayout
            android:id="@+id/inputRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="8dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- Keyboard toggle -->
            <ImageButton
                android:id="@+id/keyboardButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_keyboard_button"
                android:src="@drawable/ic_keyboard"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:contentDescription="@string/assist_toggle_keyboard"
                app:tint="@color/assistant_hint" />

            <!-- Text input (hidden by default, shown on keyboard toggle) -->
            <EditText
                android:id="@+id/textInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/assistant_text"
                android:textColorHint="@color/assistant_input_hint"
                android:hint="@string/assist_input_hint"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:visibility="gone" />

            <!-- Spacer (when input is hidden) -->
            <View
                android:id="@+id/inputSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/cancelListeningButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_cancel_button"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/assist_cancel"
                android:textColor="@color/assistant_button_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Mic button -->
            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_mic_button"
                android:src="@drawable/ic_mic"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:contentDescription="@string/assist_mic_button"
                app:tint="@color/assistant_on_accent" />

        </LinearLayout>

        <!-- Bottom safe area spacer -->
        <View
            android:id="@+id/bottomSpacer"
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>


    <!-- Persistent chat card — height set in code so layout_weight works on chatScrollView -->
    <LinearLayout
        android:id="@+id/responseCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_response_card"
        android:orientation="vertical"
        android:elevation="8dp"
        android:visibility="visible">

        <!-- AURA header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="AURA"
            android:textColor="@color/assistant_primary_text"
            android:textSize="13sp"
            android:letterSpacing="0.35"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp" />

        <View
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/assistant_branding"
            android:layout_marginBottom="10dp" />

        <!-- Scrollable chat log — height is wrap_content, capped at 80% in code -->
        <ScrollView
            android:id="@+id/chatScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="ifContentScrolls"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/chatLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

        </ScrollView>

        <!-- Compact wave bars shown while mic is active -->
        <com.example.mobile_assistant.StaticWaveView
            android:id="@+id/cardWaveView"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="8dp"
            android:visibility="gone" />

        <!-- Thinking status text (shown while waiting for GPT) -->
        <TextView
            android:id="@+id/cardStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/assistant_status"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/assistant_separator" />

        <!-- Input row: keyboard toggle | text input (hidden) | spacer | mic/send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageButton
                android:id="@+id/cardKeyboardButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_keyboard_button"
                android:src="@drawable/ic_keyboard"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:contentDescription="@string/assist_type_follow_up"
                app:tint="@color/assistant_hint" />

            <EditText
                android:id="@+id/cardTextInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_input_field"
                android:textColor="@color/assistant_text"
                android:textColorHint="@color/assistant_input_hint"
                android:hint="@string/assist_follow_up_hint"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:paddingHorizontal="18dp"
                android:singleLine="true"
                android:imeOptions="actionSend"
                android:visibility="gone" />

            <View
                android:id="@+id/cardInputSpacer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/cardCancelListeningButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_cancel_button"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/assist_cancel"
                android:textColor="@color/assistant_button_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/cardMicButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_mic_button"
                android:src="@drawable/ic_mic"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:contentDescription="@string/assist_ask_follow_up"
                app:tint="@color/assistant_on_accent" />

        </LinearLayout>

        <View
            android:id="@+id/cardBottomSpacer"
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>


</FrameLayout>
