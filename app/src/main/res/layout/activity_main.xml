<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/assistant_primary"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Section (coral, connects seamlessly with status bar) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:background="@color/assistant_primary">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_aura_logo"
                    android:scaleType="fitCenter"
                    android:contentDescription="Aura logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Your intelligent voice assistant"
                    android:textColor="#CCFFFFFF"
                    android:textSize="15sp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Main Content (surface background) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/assistant_surface">

            <!-- Setup Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETUP"
                    android:textColor="@color/assistant_primary_text"
                    android:textSize="11sp"
                    android:letterSpacing="0.14"
                    android:paddingBottom="14dp" />

                <!-- Step 1: API Key Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/assistant_card_stroke"
                    app:cardBackgroundColor="@color/assistant_card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Card header row (always visible) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="1"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_step_badge"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/api_key_heading"
                                android:textColor="@color/assistant_text"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Form shown when no API key is set -->
                        <LinearLayout
                            android:id="@+id/layoutApiKey"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingTop="12dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/api_key_description"
                                android:textColor="@color/assistant_hint"
                                android:textSize="14sp"
                                android:lineSpacingMultiplier="1.4"
                                android:paddingBottom="14dp" />

                            <EditText
                                android:id="@+id/editApiKey"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/api_key_hint"
                                android:inputType="textVisiblePassword"
                                android:maxLines="1"
                                android:importantForAutofill="no"
                                android:background="@drawable/bg_input_field"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="12dp" />

                            <Button
                                android:id="@+id/btnSaveApiKey"
                                style="@style/Widget.Material3.Button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:layout_marginTop="12dp"
                                android:text="@string/api_key_save"
                                android:backgroundTint="@color/assistant_primary" />

                        </LinearLayout>

                        <!-- Instructions shown when API key is set -->
                        <TextView
                            android:id="@+id/textInstructions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingTop="10dp"
                            android:text="@string/main_instructions"
                            android:textColor="@color/assistant_hint"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Step 2: Spotify Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/assistant_card_stroke"
                    app:cardBackgroundColor="@color/assistant_card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="2"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_step_badge"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/spotify_heading"
                                android:textColor="@color/assistant_text"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/textSpotifyStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/spotify_status_not_connected"
                            android:textColor="@color/assistant_hint"
                            android:textSize="14sp"
                            android:paddingBottom="14dp" />

                        <Button
                            android:id="@+id/btnSpotifyLogin"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/spotify_connect"
                            app:strokeColor="@color/assistant_primary"
                            android:textColor="@color/assistant_primary" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Step 3: Accessibility Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/assistant_card_stroke"
                    app:cardBackgroundColor="@color/assistant_card_bg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingBottom="10dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="3"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:background="@drawable/bg_step_badge"
                                android:layout_marginEnd="12dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/accessibility_heading"
                                android:textColor="@color/assistant_text"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/accessibility_service_description"
                            android:textColor="@color/assistant_hint"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.4"
                            android:paddingBottom="14dp" />

                        <Button
                            android:id="@+id/btnAccessibility"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/open_accessibility_settings"
                            app:strokeColor="@color/assistant_accent"
                            android:textColor="@color/assistant_accent" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="4dp"
                android:paddingBottom="40dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/assistant_separator"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By using Aura, you agree to our"
                    android:textColor="@color/assistant_hint"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="6dp">

                    <TextView
                        android:id="@+id/btnTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terms &amp; Conditions"
                        android:textColor="@color/assistant_primary"
                        android:textSize="13sp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="·"
                        android:textColor="@color/assistant_hint"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/btnPrivacy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy Policy"
                        android:textColor="@color/assistant_primary"
                        android:textSize="13sp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="6dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
